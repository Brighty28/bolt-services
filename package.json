{
  "name": "bolt-industrial-engineering-services",
  "version": "1.0.0",
  "description": "Bolt Industrial Engineering Services - One page engineering site",
  "scripts": {
    "sass": "sass src/sass/main.scss dist/css/style.css --style compressed",
    "sass:watch": "sass src/sass/main.scss dist/css/style.css --watch",
    "build": "npm run sass && npm run copy",
    "copy": "node scripts/copy.js",
    "dev": "npm run build && npx concurrently \"npm run sass:watch\" \"node server.js\"",
    "start": "npm run build && node server.js",
    "serve": "npx serve dist -l 3000",
    "deploy": "npm ci --production=false && npm run build",
    "production": "NODE_ENV=production node server.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "sass": "^1.72.0",
    "serve": "^14.2.0"
  },
  "dependencies": {
    "nodemailer": "^8.0.3"
  }
}
