# Bolt Services — Environment Variables
# Copy this file to .env and fill in your values (or set in Plesk Node.js settings)

# Server port (Plesk/Passenger will set this automatically)
PORT=3000

# CMS Admin credentials (required in production)
# When both are set, /admin and /api routes require HTTP Basic Auth
# When both are empty, auth is disabled (local development)
CMS_ADMIN_USER=
CMS_ADMIN_PASS=
